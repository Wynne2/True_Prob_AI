# ============================================================
# NBA Prop AI - Environment Variable Template
# ============================================================
# Copy this file to .env and fill in your real keys.
# Lines starting with # are comments and are ignored.
# You do NOT need all keys - missing providers are skipped
# gracefully and the system falls back to sample data.
# ============================================================

# ------------------------------------------------------------
# TIER 1 - PRIMARY PROVIDERS
# ------------------------------------------------------------

# SportsDataIO (schedules, rosters, injuries, odds, props, stats)
# Get your key at: https://sportsdata.io/
SPORTSDATAIO_API_KEY=

# Sportradar (official NBA game + player + schedule + odds data)
# Get your key at: https://developer.sportradar.com/
SPORTRADAR_API_KEY=

# The Odds API (live sportsbook odds comparison, player props)
# Get your key at: https://the-odds-api.com/
THE_ODDS_API_KEY=

# FantasyPros (rankings, projections, fantasy context enrichment)
# Get your key at: https://www.fantasypros.com/nba/
FANTASYPROS_API_KEY=

# NBA Official Developer API
# Apply at: https://developer.nba.com/
NBA_OFFICIAL_API_KEY=

# ------------------------------------------------------------
# TIER 2 - OPTIONAL / LICENSED PROVIDERS
# ------------------------------------------------------------

# StatMuse (licensed API access required)
STATMUSE_API_KEY=

# RotoGrinders (no documented public API - leave blank unless licensed)
ROTOGRINDERS_API_KEY=

# RotoWire (no documented public API - leave blank unless licensed)
ROTOWIRE_API_KEY=

# ------------------------------------------------------------
# CSV IMPORT (optional - overrides sample data per file)
# ------------------------------------------------------------

# Paths to CSV override files (relative to project root)
# CSV_PLAYERS_PATH=data/import/players.csv
# CSV_ODDS_PATH=data/import/odds.csv
# CSV_DEFENSE_PATH=data/import/defense.csv

# ------------------------------------------------------------
# APPLICATION SETTINGS (optional)
# ------------------------------------------------------------

# Logging level: DEBUG, INFO, WARNING, ERROR
# LOG_LEVEL=INFO

# Write logs to file in addition to stdout
# LOG_TO_FILE=false
# LOG_FILE=nba_prop_ai.log

# In-memory cache TTL in seconds (0 = disable)
# CACHE_TTL=300

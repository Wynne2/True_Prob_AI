# ============================================================
# NBA Prop AI - Environment Variable Template
# ============================================================
# Copy this file to .env and fill in your real keys.
# Lines starting with # are comments and are ignored.
#
# REQUIRED for live data:
#   - SPORTSDATAIO_API_KEY  (injuries, rosters, season stats, depth charts)
#   - THE_ODDS_API_KEY      (sportsbook odds, prop lines)
#
# RECOMMENDED for full slate support:
#   - SPORTRADAR_API_KEY    (game schedule primary)
#
# NOT REQUIRED:
#   - nba_api uses public NBA.com endpoints — no key needed.
#
# RETIRED (no longer used in the engine):
#   - BALLDONTLIE_API_KEY, FANTASYPROS_API_KEY, NBA_OFFICIAL_API_KEY
#   - STATMUSE_API_KEY, ROTOGRINDERS_API_KEY, ROTOWIRE_API_KEY
# ============================================================

# ------------------------------------------------------------
# PLAYER-PROP MODELING DATA  (PRIMARY: SportsDataIO)
# SOURCE: injuries, rosters, season stats, depth charts, game logs
# Get your key at: https://sportsdata.io/
# ------------------------------------------------------------
SPORTSDATAIO_API_KEY=

# ------------------------------------------------------------
# SPORTSBOOK ODDS  (The Odds API — ONLY source for pricing)
# SOURCE: prop lines, over/under prices, line shopping
# Get your key at: https://the-odds-api.com/
# ------------------------------------------------------------
THE_ODDS_API_KEY=

# ------------------------------------------------------------
# SLATE / GAME SCHEDULE  (Sportradar — primary slate source)
# SOURCE: today's games, game IDs, team matchups, start times
# Get your key at: https://developer.sportradar.com/
# ------------------------------------------------------------
SPORTRADAR_API_KEY=

# ------------------------------------------------------------
# nba_api — NO KEY REQUIRED
# Uses public NBA.com endpoints.  install: pip install nba_api
# SOURCE (primary): usage rate, touches, possessions, pace, splits
# ------------------------------------------------------------
# NBA_SEASON=2024-25          # season string for nba_api calls
# NBA_API_SLEEP=0.6           # seconds between nba_api requests (rate limit)
# NBA_API_TTL_ADVANCED=86400  # cache TTL for advanced dashboard (seconds)
# NBA_API_TTL_TRACKING=86400  # cache TTL for tracking dashboard (seconds)
# NBA_API_TTL_GAMELOGS=43200  # cache TTL for player game logs (seconds)
# NBA_API_TTL_SPLITS=86400    # cache TTL for split dashboards (seconds)

# ------------------------------------------------------------
# CSV IMPORT (optional — overrides any source per file)
# ------------------------------------------------------------
# CSV_PLAYERS_PATH=data/import/players.csv
# CSV_ODDS_PATH=data/import/odds.csv
# CSV_DEFENSE_PATH=data/import/defense.csv

# ------------------------------------------------------------
# APPLICATION SETTINGS
# ------------------------------------------------------------
# LOG_LEVEL=INFO          # DEBUG, INFO, WARNING, ERROR
# LOG_TO_FILE=false
# LOG_FILE=nba_prop_ai.log
# CACHE_TTL=300           # in-memory cache TTL in seconds (0 = disable)
# DISK_CACHE_ENABLED=true # set to false to disable disk caching
